<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sale Point - Cold Store Manager</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
</head>
<body>
    <div class="landing-container">
        <div class="landing-card">
            <div class="logo-section">
                <span class="material-icons logo-icon">store</span>
                <h1>Sale Point</h1>
                <p class="tagline">Smart Cold Store Management</p>
            </div>
            
            <div class="action-buttons">
                <a href="/login" class="btn btn-primary btn-large">
                    <span class="material-icons">login</span>
                    Sign In
                </a>
                <a href="/register" class="btn btn-outline btn-large">
                    <span class="material-icons">storefront</span>
                    Register Your Shop
                </a>
            </div>
            
            <div class="features">
                <div class="feature-item">
                    <span class="material-icons">inventory</span>
                    <span>Track Stock</span>
                </div>
                <div class="feature-item">
                    <span class="material-icons">point_of_sale</span>
                    <span>Daily Sales</span>
                </div>
                <div class="feature-item">
                    <span class="material-icons">analytics</span>
                    <span>Profit Reports</span>
                </div>
            </div>
        </div>
    </div>
</body>
</html>